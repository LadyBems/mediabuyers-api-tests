{
    "name": "qa/mediabuyers-api-tests",
    "description": "API automation suite for the Media Buyers REST resource (PHP + Codeception).",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "codeception/codeception": "^5.1",
        "codeception/module-rest": "^3.4",
        "codeception/module-phpbrowser": "^3.0",
        "codeception/module-asserts": "^3.0",
        "vlucas/phpdotenv": "^5.6",
        "justinrainbow/json-schema": "^5.2"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/Support/"
        }
    },
    "config": {
        "allow-plugins": {
            "codeception/codeception": true
        }
    }
}
